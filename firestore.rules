rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /footprints/{entryId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin() || resource.data.ownerId == request.auth.uid;

      match /participants/{userId} {
        allow read: if signedIn();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /communities/{communityId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    match /leaderboards/{boardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
